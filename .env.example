APP_ENV=development
DEBUG=true
HOST=127.0.0.1
PORT=8000
RELOAD=true

# Set a strong value before production deployment.
JWT_SECRET=change-this-demo-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Leave blank for local SQLite, or set a full production URL such as:
# postgresql+psycopg://user:password@host:5432/sentinel_ids
DATABASE_URL=
DATABASE_PATH=sentinel_ids.db

# Comma-separated list for cross-origin deployments.
ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
